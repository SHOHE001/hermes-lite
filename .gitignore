# Python
__pycache__/
*.pyc
*.pyo

# venv
.venv/
venv/

# 機密
.env
.token
*.key

# 自動生成データ / ログ / 状態
**/sessions.sqlite*
**/.usage.json
**/state/runs/
**/state/curator_state.json
**/state/*.log
**/state/on-stop.log

# ジョブ実行ログ・コスト（bin/run-claude.sh 出力、ローカル限定）
logs/

# gloop
features/.loop/last-cycle-marker
features/.loop/*.pid
features/.batch/lock

# gloop-work レビュー実行の中間/結果ファイル（plan.md と rejection.md に判定要約を残せば十分）
features/*/codex-design*.yaml
features/*/codex-design*.yaml.verdict.json
features/*/codex-final*.yaml
features/*/codex-final*.yaml.verdict.json
features/*/codex-input.md
features/*/judgment-summary.md
features/*/plan-snapshots/

# Claude Code settings (gloop の hook が production 側 ~/hermes-lite/ に流れて
# Discord bot の claude -p を guard で詰まらせるのを防ぐため、settings.json は
# git 管理せず settings.json.example を雛形に各 clone がローカルで配置する)
.claude/settings.json
.claude/settings.local.json

# Issue #3 承認ゲート: var/approvals.sqlite ほか runtime データ
var/*
!var/.gitkeep

# Issue #4 goals-nudge: ユーザー個人の目標ファイル（個人情報・未公開予定が混ざり得る）
# `goals.md.example` から `cp goals.md.example goals.md` してローカル編集する
/goals.md
