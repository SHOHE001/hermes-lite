# mail-watch: Gmail ラベル `hermes-lite` を貼った未読 thread を検出し
# Discord に通知するジョブ。詳細は docs/jobs-mail-watch.md を参照。
ALLOWED_TOOLS="mcp__claude_ai_Gmail__list_labels mcp__claude_ai_Gmail__search_threads mcp__claude_ai_Gmail__get_thread mcp__claude_ai_Gmail__label_thread mcp__claude_ai_Gmail__unlabel_thread"
MAX_TURNS="40"
TIMEOUT_SEC="300"
MAX_BUDGET_USD="1.00"
MODEL="sonnet"
NOTIFY_RESULT="1"
NOTIFY_ON_ERROR="1"
# 0 件時に prompt が返す `[NOOP]` をラッパー側で検知して Discord 投稿をスキップする（opt-in）。
SUPPRESS_RESULT_IF="[NOOP]"
