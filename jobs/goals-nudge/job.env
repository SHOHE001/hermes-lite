# goals-nudge: 週次 goals nudge。詳細は docs/jobs-goals-nudge.md を参照。
ALLOWED_TOOLS="Read Bash(date:*)"
MAX_TURNS="20"
TIMEOUT_SEC="120"
MAX_BUDGET_USD="0.50"
MODEL="sonnet"
NOTIFY_RESULT="1"
NOTIFY_ON_ERROR="1"
# active 0 件 かつ parse 失敗 0 件 のとき prompt が "[NOOP]" を返す。
# ラッパーが exact match で検知して Discord 投稿をスキップする。
SUPPRESS_RESULT_IF="[NOOP]"
