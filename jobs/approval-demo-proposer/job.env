# approval-demo-proposer: 承認ゲート (#3) の動作確認用 proposer ジョブ。
# Bash で payload を python3 で生成 → approvals.py enqueue → 承認依頼本文を Discord に。
# ALLOWED_TOOLS="" のとき bin/run-claude.sh は --allowed-tools を一切渡さず Claude
# デフォルト tool (Bash 含む) を使える。disallowed-tools.txt の Bash(rm *) 等は別途禁止。
ALLOWED_TOOLS=""
MAX_TURNS="3"
TIMEOUT_SEC="60"
MAX_BUDGET_USD="0.50"
MODEL="sonnet"
NOTIFY_RESULT="1"
NOTIFY_ON_ERROR="1"
