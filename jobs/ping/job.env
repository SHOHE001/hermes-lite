# 動作確認用ダミージョブ。
# 結果の文字列をそのまま Discord に流す。スケジュールは付けず手動実行のみ。
ALLOWED_TOOLS=""
MAX_TURNS="1"
TIMEOUT_SEC="60"
# --max-budget-usd は Max サブスク利用時も「計算上のコスト」で判定される。
# claude -p のシステムプロンプト読み込みだけで $0.05〜0.10 かかるため、
# 0.5 ドル以上の余裕を持たせる（実課金はサブスク枠で 0）。
MAX_BUDGET_USD="0.50"
MODEL="sonnet"
NOTIFY_RESULT="1"
NOTIFY_ON_ERROR="1"
