[Unit]
Description=hermes-lite Discord gateway (Discord -> claude -p)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/hermes-lite/gateway/discord
ExecStart=%h/hermes-lite/gateway/discord/.venv/bin/python %h/hermes-lite/gateway/discord/bot.py
EnvironmentFile=%h/hermes-lite/.env
Environment=PATH=%h/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
# bot 経由で claude が systemctl --user を叩けるよう（ジョブ作成自動化用）
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
Restart=on-failure
RestartSec=5
# Hardening
ProtectSystem=full
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=default.target
