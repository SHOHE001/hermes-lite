# Discord bot token (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# 反応する Discord User ID (カンマ区切り、複数可)
# 取得: Discord クライアントで Developer Mode ON → 自分のアイコン右クリック → "ID をコピー"
ALLOWED_USER_IDS=

# claude -p のタイムアウト秒 (デフォルト 300)
HERMES_DISCORD_TIMEOUT_SEC=300

# claude バイナリのパス (デフォルト ~/.local/bin/claude)
# CLAUDE_BIN=/home/shohei/.local/bin/claude
